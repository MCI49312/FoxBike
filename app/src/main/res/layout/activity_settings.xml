<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/settings"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language"
                android:layout_marginTop="8dp"/>
            <Spinner
                android:id="@+id/spinnerLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/units"
                android:layout_marginTop="8dp"/>
            <Spinner
                android:id="@+id/spinnerUnits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <CheckBox
                android:id="@+id/cbUseMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/use_maps_beta"
                android:layout_marginBottom="8dp"/>

            <CheckBox
                android:id="@+id/cbVoiceFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/voice_feedback"
                android:layout_marginBottom="8dp"/>

            <CheckBox
                android:id="@+id/cbServiceReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/service_reminder"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnServiceSettings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/service_settings"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/cbDarkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dark_mode"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weather_location"
                android:layout_marginTop="8dp"/>
            <AutoCompleteTextView
                android:id="@+id/etWeatherLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:completionThreshold="1"
                android:hint="Budapest" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wind_unit"
                android:layout_marginTop="8dp"/>
            <Spinner
                android:id="@+id/spinnerWindUnits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weight"
                android:layout_marginTop="8dp"/>
            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:hint="70" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_telemetry_note"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnResetOdometer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_odometer"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/layoutDemoMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEMO MODE SETTINGS"
                    android:textStyle="bold"
                    android:textColor="#FF0000"
                    android:layout_marginTop="16dp"/>

                <EditText
                    android:id="@+id/etFakeSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/fake_speed"
                    android:inputType="numberDecimal"/>

                <EditText
                    android:id="@+id/etFakeOdometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/fake_odometer"
                    android:inputType="numberDecimal"/>

                <EditText
                    android:id="@+id/etFakeTrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/fake_trip"
                    android:inputType="numberDecimal"/>

                <Button
                    android:id="@+id/btnSaveDemo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/save"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/version"
                android:gravity="center"
                android:textColor="#888888"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>