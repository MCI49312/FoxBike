<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/settings"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language"
                android:textColor="#888888"
                android:textSize="12sp" />
            <Spinner
                android:id="@+id/spinnerLanguage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_name"
                android:textColor="#888888"
                android:textSize="12sp" />
            <EditText
                android:id="@+id/etSettingsName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/enter_name"
                android:inputType="textPersonName"
                android:autofillHints="name"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_vehicle"
                android:textColor="#888888"
                android:textSize="12sp" />
            <Spinner
                android:id="@+id/spinnerSettingsVehicle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etSettingsWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/weight"
                android:inputType="numberDecimal"
                android:autofillHints="none"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/layoutUpdater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="?android:attr/colorBackgroundFloating"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvUpdaterBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Branch: main"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

                <Button
                    android:id="@+id/btnCheckUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/check_updates"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weather_location"
                android:textColor="#888888"
                android:textSize="12sp" />
            <AutoCompleteTextView
                android:id="@+id/etSettingsWeatherLoc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/weather_location"
                android:inputType="text"
                android:completionThreshold="1"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <Spinner
                    android:id="@+id/spinnerTempUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
                <Spinner
                    android:id="@+id/spinnerWindUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <Spinner
                android:id="@+id/spinnerDistanceUnit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnSwitchUI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/use_old_ui"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnResetOdo"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_odometer"
                android:textColor="#FF0000"
                app:strokeColor="#FF0000"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnFullReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/full_app_reset"
                android:textColor="#FF0000"
                app:strokeColor="#FF0000"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnExportGpx"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/export_gpx"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvSettingsVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/version"
                android:gravity="center"
                android:textColor="#888888"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>