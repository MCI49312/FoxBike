<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/active_trip_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSpeed"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        android:backgroundTint="#F8F8F8"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvActiveSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_placeholder"
                android:textSize="100sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvActiveSpeedUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/unit_kmh"
                android:textSize="20sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        android:backgroundTint="#F8F8F8"
        app:layout_constraintTop_toBottomOf="@+id/cardSpeed">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="16dp">

            <include layout="@layout/item_stat_small" android:id="@+id/activeAvgSpeed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
            <include layout="@layout/item_stat_small" android:id="@+id/activeTrip" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />
            <include layout="@layout/item_stat_small" android:id="@+id/activeTime" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" />

            <include layout="@layout/item_stat_small" android:id="@+id/activeMaxSpeed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="16dp" />
            <include layout="@layout/item_stat_small" android:id="@+id/activeElevation" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="16dp" />
            <include layout="@layout/item_stat_small" android:id="@+id/activeCalories" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginTop="16dp" />
        </GridLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWeather"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        android:backgroundTint="#F8F8F8"
        app:layout_constraintTop_toBottomOf="@+id/cardStats">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tvActiveWeather"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/weather" />
            <TextView
                android:id="@+id/tvActiveWind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wind" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutActiveControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnActiveStats"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/statistics_btn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnActivePause"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="@string/pause"
                android:layout_marginEnd="8dp"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/btnActiveStop"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="@string/stop_trip"
                android:backgroundTint="#FF0000"
                android:layout_marginStart="8dp"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>